# Copy to .env.local and fill in real values. Never commit real keys.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (server-side only — never expose to client)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Local dev: run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# Production: create a webhook endpoint in the Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs (price_..., NOT product prod_... ids)
STRIPE_PRICE_STARTER=price_...   # 10 credits for $5
STRIPE_PRICE_STANDARD=price_...  # 50 credits for $18
STRIPE_PRICE_PRO=price_...       # 150 credits for $45

# App URL (used for Stripe redirects and Supabase auth)
NEXT_PUBLIC_APP_URL=http://localhost:3000
